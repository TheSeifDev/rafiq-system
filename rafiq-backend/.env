# ─────────────────────────── Core security / runtime ───────────────────────────
# REQUIRED in production.
API_KEY=rafiq-secret-key-2026-x8k9m2p

# Local-development escape hatch only (do NOT enable in production).
ALLOW_INSECURE_DEV_API_KEY=0
INSECURE_DEV_API_KEY=dev-insecure-api-key

# Optional CORS allowlist. Comma-separated. Example:
# CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:5173
CORS_ORIGINS=*

# Optional DB/schema override paths (relative paths are resolved under project root).
RAFIQ_DB_PATH=rafiq.db
RAFIQ_SCHEMA_PATH=schema.sql

# ─────────────────────────── Supabase sync (optional) ───────────────────────────
# Leave SUPABASE_URL and SUPABASE_KEY blank to run fully offline.
SUPABASE_URL=https://mtiqqlklskknumzgzzcx.supabase.co
SUPABASE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Im10aXFxbGtsc2trbnVtemd6emN4Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzcwMzAyNDcsImV4cCI6MjA5MjYwNjI0N30.68hZ-9cqYBQ2-s9LH1mrQAM57FCf5kvyJvBS9VZ-VnY

# Push/pull loop settings (seconds).
