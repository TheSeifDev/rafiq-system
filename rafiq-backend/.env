# ─────────────────────────── RAFIQ Backend ───────────────────────────
# Production Environment

# ── Security ─────────────────────────────────────────────────────────
# REQUIRED
RAFIQ_API_KEY=rafiq-secret-key-2026-x8k9m2p

# Dev only (DO NOT enable in production)
ALLOW_INSECURE_DEV_API_KEY=0
INSECURE_DEV_API_KEY=dev-insecure-api-key

# ── Server ───────────────────────────────────────────────────────────
PORT=3001
HOST=0.0.0.0
NODE_ENV=production

# Optional CORS allowlist
# Example:
# CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:5173
CORS_ORIGINS=*

# ── Database ─────────────────────────────────────────────────────────
DB_PATH=./rafiq.db
SCHEMA_PATH=./schema.sql

# ── AI ───────────────────────────────────────────────────────────────
# Optional if using Claude API
ANTHROPIC_API_KEY=

# Optional if using local Ollama
OLLAMA_URL=http://127.0.0.1:11434

# ── Supabase Sync (Optional) ────────────────────────────────────────
# Leave blank for full offline mode
SUPABASE_URL=https://amwuretboybrbxxmston.supabase.co
SUPABASE_KEY=sb_publishable_fLAPdacoB0Q4Ap7FC-srug_hl8Pyvpz

# Sync settings
SUPABASE_SYNC_INTERVAL=30
SUPABASE_PULL_INTERVAL=60
SUPABASE_TIMEOUT=5

# Queue protection
SYNC_QUEUE_BATCH_SIZE=100
SYNC_MAX_ERROR_COUNT=5

# ── MQTT / Smart Home ───────────────────────────────────────────────
# Leave empty to disable MQTT
MQTT_BROKER=mqtt://127.0.0.1:1883

# Optional auth
MQTT_USER=
MQTT_PASS=