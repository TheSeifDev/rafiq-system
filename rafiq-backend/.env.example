# ─────────────────────────── RAFIQ Backend ───────────────────────────
# Copy this file to .env and fill in your values

# ── Server ───────────────────────────────────────────────────────────
PORT=3001
HOST=0.0.0.0
NODE_ENV=production

# ── Security ─────────────────────────────────────────────────────────
RAFIQ_API_KEY=your-secret-key

# ── Database ─────────────────────────────────────────────────────────
DB_PATH=./data/rafiq.db

# ── AI (Local Ollama) ───────────────────────────────────────────────
OLLAMA_URL=http://127.0.0.1:11434

# ── Supabase Sync (Optional — leave blank for full offline) ─────────
SUPABASE_URL=
SUPABASE_KEY=

# ── MQTT / Smart Home ───────────────────────────────────────────────
MQTT_BROKER=mqtt://127.0.0.1:1883
MQTT_USER=
MQTT_PASS=
